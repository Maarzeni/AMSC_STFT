Bootstrap: docker
From: ubuntu:22.04

%labels
    Author Matilde Colombo, Marta Arzeni
    Version v2.0
    Description Apptainer container for High-Performance STFT Audio Analysis

%environment
    # Environment variables available at runtime
    export LC_ALL=C
    export OMPI_MCA_rmaps_base_oversubscribe=1
    # Add the build binaries to the system PATH so they can be run directly
    export PATH=/AMSC_STFT/ft_project/build/examples:/AMSC_STFT/ft_project/build/benchmarks:$PATH

%post
    # Prevent timezone/keyboard interactive dialogs during apt-get
    export DEBIAN_FRONTEND=noninteractive

    # Install C++ toolchain, CMake, OpenMP, and MPI
    apt-get update -qq
    apt-get install -y build-essential cmake libomp-dev openmpi-bin libopenmpi-dev

    # Build the project inside the container immutably
    cd /AMSC_STFT/ft_project
    mkdir -p build
    cd build
    cmake .. -DCMAKE_BUILD_TYPE=Release
    make -j$(nproc)

%files
    # Copy the entire ft_project directory into the container
    ft_project /AMSC_STFT/ft_project

%runscript
    # Default execution when running `apptainer run amsc_stft.sif`
    # We execute the main executable, passing any arguments forwarded by the user.
    # Replace "main" with the actual name of your compiled target if different.
    exec /AMSC_STFT/ft_project/build/examples/main "$@"